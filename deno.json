{
  "compilerOptions": {
    "lib": ["deno.ns", "deno.window"]
  },
  "tasks": {
    "build:manifest": "deno run --allow-read=./ --allow-write=./ scripts/build-manifest.ts",
    "build:manifest:patch": "deno run --allow-read=./ --allow-write=./ scripts/build-manifest.ts --patch",
    "release": "deno run --allow-read=./ --allow-run=gh scripts/release.ts"
  }
}
