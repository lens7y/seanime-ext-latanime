{
  "compilerOptions": {
    "lib": ["deno.ns", "deno.window"]
  },
  "permissions": {
    "build": {
      "read": ["./"],
      "write": ["./"],
      "env": ["GITHUB_REPO", "GITHUB_REF"]
    },
    "release": {
      "read": ["./"],
      "write": ["./"],
      "env": ["GITHUB_REPO", "GITHUB_REF"],
      "run": ["git", "sh", "deno"],
      "net": true
    },
    "release-push": {
      "read": ["./"],
      "write": ["./"],
      "env": ["GITHUB_REPO", "GITHUB_REF"],
      "run": ["git", "sh"],
      "net": true
    },
    "dev": {
      "read": ["./"],
      "write": ["./"],
      "env": ["DEV_PORT", "DEV_HOST"],
      "net": true
    },
    "test": {
      "read": ["./"],
      "write": ["./.test-artifacts"],
      "net": true
    }
  },
  "tasks": {
    "build:manifest": "deno run -P=build scripts/build-manifest.ts",
    "release": "deno run -P=release scripts/release.ts",
    "release:push": "deno run -P=release-push scripts/release.ts --push",
    "dev": "deno task dev:manifest && deno task dev:serve",
    "dev:manifest": "deno run -P=dev scripts/dev-manifest.ts",
    "dev:serve": "deno run -P=dev scripts/dev-serve.ts",
    "test:smoke": "deno run -P=test scripts/smoke.ts",
    "test:stream": "deno run -P=test scripts/stream-smoke.ts"
  }
}
